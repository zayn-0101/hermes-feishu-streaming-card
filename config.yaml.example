# Hermes Feishu Streaming Card V3.4.3 sidecar configuration
# Copy to a local path and fill credentials from your environment or secret store.
# Default config path: ~/.hermes_feishu_card/config.yaml

server:
  host: 127.0.0.1
  port: 8765

# ── Single Profile (minimal) ─────────────────────────────────────────────────
# For simple setups with one Hermes profile and optionally multiple bots.
feishu:
  # Prefer FEISHU_APP_ID and FEISHU_APP_SECRET environment variables.
  # In multi-profile mode (see profiles section below), these top-level
  # values are ignored — each profile provides its own credentials.
  app_id: ""
  app_secret: ""
  base_url: https://open.feishu.cn/open-apis
  timeout_seconds: 30

card:
  # Global fallback title. profiles.<id>.card.title and bots.items.<id>.card.title
  # can override it; bot title wins over profile title.
  title: Hermes Agent
  max_wait_ms: 800
  max_chars: 240
  # Footer fields and order. Supported values:
  # duration, model, input_tokens, output_tokens, context
  footer_fields:
    - duration
    - model
    - input_tokens
    - output_tokens
    - context

# ── Multi-Bot (optional) ─────────────────────────────────────────────────────
# Define multiple Feishu bots under bots.items. Each bot gets its own
# app_id/app_secret. Bind chat IDs to bots via bindings.chats.
# Unbound sessions use bindings.fallback_bot.
#
# Note: V3.3.0 does NOT filter group triggers. Hermes Gateway still decides
# whether to respond based on its own rules (mention, private, reply, etc.).
# The sidecar only ensures the card is sent via the correct bot.
bots:
  default: default
  items: {}
  # Example:
  # sales:
  #   name: Sales Group Bot
  #   app_id: cli_sales_xxxxx
  #   app_secret: ""
  #   card:
  #     title: Sales Bot
  # support:
  #   name: Support Bot
  #   app_id: cli_support_yyyyy
  #   app_secret: ""
  #   card:
  #     title: Support Bot

bindings:
  fallback_bot: default
  chats: {}
  # Example:
  # oc_xxxxxxxxxxxx: sales
  # oc_yyyyyyyyyyyy: support
  group_rules:
    enabled: false  # V3.3.0 does not filter group triggers

# ── Multi-Profile (V3.3.0+, optional) ────────────────────────────────────────
# For setups with multiple Hermes profiles sharing one sidecar process.
# When profiles is non-empty, the top-level feishu/bots/bindings sections
# above are IGNORED. Each profile provides its own independent credentials,
# bot registry, and chat bindings.
# Each profile may set card.title for its default title; each bot may set
# card.title for per-bot branding. Bot title has the highest priority.
#
# FEISHU_APP_ID and FEISHU_APP_SECRET environment variables are also
# ignored in multi-profile mode.
#
# Uncomment and customize:
#
# profiles:
#   default:
#     feishu:
#       app_id: "cli_default_xxx"
#       app_secret: ""
#       base_url: https://open.feishu.cn/open-apis
#       timeout_seconds: 30
#     bots:
#       default: default
#       items: {}
#     bindings:
#       fallback_bot: default
#       chats: {}
#     card:
#       title: Default Profile
#
#   work:
#     feishu:
#       app_id: "cli_work_yyy"
#       app_secret: ""
#       base_url: https://open.feishu.cn/open-apis
#       timeout_seconds: 30
#     bots:
#       default: default
#       items:
#         default:
#           name: Work Bot
#           app_id: "cli_work_yyy"
#           app_secret: ""
#           card:
#             title: Work Bot
#     bindings:
#       fallback_bot: default
#       chats: {}
#     card:
#       title: Work Profile
